# API URL (your backend server)
EXPO_PUBLIC_API_URL=http://localhost:4000

# Miner proxy URL (web builds — defaults to API URL; use local-proxy.js for dev)
EXPO_PUBLIC_MINER_PROXY_URL=http://localhost:4000

# RevenueCat SDK keys (from app.revenuecat.com)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Expo project ID (from expo.dev)
EXPO_PUBLIC_PROJECT_ID=7e9a5883-0170-44fc-be43-ccba1e11db30
