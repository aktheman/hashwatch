# API URL (your backend server)
EXPO_PUBLIC_API_URL=http://localhost:4000

# RevenueCat (native in-app purchases)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Get production keys from https://app.revenuecat.com
# For local dev, use test keys prefixed with "test_" or "goog_"

# Stripe (web checkout)
EXPO_PUBLIC_STRIPE_PRICE_ID=price_pro_monthly
# Get this from https://dashboard.stripe.com/products -> your Price ID

# PostHog (analytics, web only)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Expo project ID (from expo.dev)
EXPO_PUBLIC_PROJECT_ID=7e9a5883-0170-44fc-be43-ccba1e11db30
