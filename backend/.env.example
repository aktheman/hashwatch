PORT=4000

# PostgreSQL settings are only used if DATABASE_URL is not set.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hashwatch
DB_USER=hashwatch
DB_PASSWORD=hashwatch

# When set, DATABASE_URL takes precedence over individual DB_* values.
# DATABASE_URL=postgres://user:***@host:5432/hashwatch

JWT_SECRET=change-this-to-a-random-secret
REVENUECAT_API_KEY=
EXPO_PUBLIC_API_URL=http://localhost:4000
SENTRY_DSN=
