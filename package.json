{
  "name": "hashwatch",
  "version": "1.0.1",
  "main": "index.ts",
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.18.0",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.17.3",
    "axios": "^1.17.0",
    "expo": "~56.0.11",
    "expo-build-properties": "^56.0.18",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-haptics": "~56.0.3",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.17",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "i18next": "^26.3.1",
    "jest": "~29.7.0",
    "posthog-js": "^1.406.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-chart-kit": "^6.12.3",
    "react-native-purchases": "^10.2.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-view-shot": "5.1.0",
    "react-native-web": "^0.21.2",
    "world-map-country-shapes": "^1.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "eas-cli": "^20.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.8.9",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest-expo": "~56.0.5",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "react-test-renderer": "19.2.3",
    "serve": "^14.2.6",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && cp public/service-worker.js dist/ 2>/dev/null; cp public/manifest.json dist/ 2>/dev/null; cp public/offline.html dist/ 2>/dev/null; true",
    "build:web:analyze": "expo export --platform web --dump-sourcemap && node scripts/analyze-bundle.js",
    "electron": "NODE_ENV=development electron electron/main.js",
    "electron:build": "npm run build:web && electron-builder",
    "postinstall": "node -e \"try{require('child_process').execSync('electron-builder install-app-deps',{stdio:'ignore'})}catch(e){}\"",
    "deploy:web": "expo export --platform web && npx vercel --prod",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "version:patch": "npm version patch --no-git-tag-version && git add package.json && git commit -m 'bump: patch'",
    "version:minor": "npm version minor --no-git-tag-version && git add package.json && git commit -m 'bump: minor'",
    "version:major": "npm version major --no-git-tag-version && git add package.json && git commit -m 'bump: major'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.hashwatch.app",
    "productName": "HashWatch",
    "directories": {
      "output": "electron-dist"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "aktheman",
        "repo": "hashwatch",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "private": true,
  "overrides": {
    "node-forge": "1.4.0",
    "tar": "7.5.16",
    "@xmldom/xmldom": "0.9.10",
    "eas-cli": {
      "ajv": "8.18.0",
      "diff": "8.0.3",
      "minimatch": "5.1.9",
      "joi": "17.13.4",
      "ts-deepmerge": "8.0.0",
      "yaml": "2.9.0"
    },
    "@expo/eas-json": {
      "joi": "17.13.4"
    },
    "js-yaml": "5.0.0",
    "uuid": "11.1.1"
  },
  "allowScripts": {
    "dtrace-provider@0.8.8": true,
    "electron@33.4.11": true
  }
}
