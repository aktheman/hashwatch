{
  "buildCommand": "npx expo export --platform web; mv dist/index.html dist/app.html; cp -f public/*.html public/*.css public/robots.txt public/sitemap.xml public/og-image.png dist/; cp -f dist/landing.html dist/index.html",
  "outputDirectory": "dist",
  "framework": null,
  "trailingSlash": false,
  "routes": [
    { "src": "^/app(?:/(.*))?$", "dest": "/app.html" },
    { "src": "^/pricing$", "dest": "/pricing.html" },
    { "src": "^/changelog$", "dest": "/changelog.html" },
    { "src": "^/blog$", "dest": "/blog.html" },
    { "src": "^/blog/(.*)$", "dest": "/blog-$1.html" },
    { "src": "^/support$", "dest": "/support.html" },
    { "src": "^/terms$", "dest": "/terms.html" },
    { "src": "^/privacy$", "dest": "/privacy.html" },
    { "src": "^/landing$", "dest": "/landing.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/_expo/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
