{
  "buildCommand": "npx expo export --platform web; mv dist/index.html dist/app.html; cp -f public/*.html public/*.css public/robots.txt public/sitemap.xml public/og-image.png dist/; cp -f dist/landing.html dist/index.html",
  "outputDirectory": "dist",
  "framework": null,
  "trailingSlash": false,
  "routes": [{ "src": "^/app(?:/(.*))?$", "dest": "/app.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/_expo/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
